rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true ||
        request.auth.token.email == "sethu.nontsele@gmail.com"
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Helpers ---
    function isValidUserProfile(data) {
      return data.uid == request.auth.uid &&
             data.gamertag is string && data.gamertag.size() >= 3 && data.gamertag.size() <= 32;
    }

    function isValidMatch(data) {
      return data.id is string && 
             data.date != null &&
             data.players is list &&
             (!('replayData' in data) || (data.replayData is string && data.replayData.size() <= 1048576));
    }

    function isValidRecommendation(data) {
      return data.uid == request.auth.uid &&
             data.status == 'pending' &&
             data.title is string && data.title.size() <= 100 &&
             data.description is string && data.description.size() <= 2000;
    }

    function isValidClan(data) {
      return data.ownerId == request.auth.uid &&
             data.name is string && data.name.size() <= 32 &&
             data.tag is string && data.tag.size() <= 4;
    }

    // --- Rules ---

    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isOwner(uid) && isValidUserProfile(incoming()) && 
                    (!('isAdmin' in incoming()) || isAdmin());
      allow update: if isOwner(uid) && isValidUserProfile(incoming()) && 
                    (incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'gamertag', 'avatarUrl', 'clanId', 'customization', 'stats', 'rank', 'progression', 'economy', 'battlePass', 'social', 'trophies', 'savedLoadout']) || isAdmin());
    }

    match /trophies/{trophyId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /recommendations/{recId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidRecommendation(incoming());
      allow update, delete: if isAdmin();
    }

    match /matches/{matchId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidMatch(incoming());
      allow update, delete: if isAdmin();
    }

    match /clans/{clanId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidClan(incoming());
      allow update: if isSignedIn() && (
        isOwner(existing().ownerId) || 
        (request.auth.uid in existing().memberIds && incoming().diff(existing()).affectedKeys().hasOnly(['memberIds', 'clanXP'])) ||
        isAdmin()
      );
      allow delete: if isAdmin() || (isSignedIn() && isOwner(existing().ownerId));
    }
    
    // Test collection
    match /test/connection {
      allow read: if true;
    }
  }
}
