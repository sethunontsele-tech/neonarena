rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, displayName, gamertag, avatarUrl, customization, stats
    //
    // Collection: matches
    // Fields: id, date, duration, mode, map, players, replayData
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // Domain Validators
    function isValidUser(data) {
      return data.uid is string && 
             data.displayName is string && 
             data.displayName.size() < 100 &&
             data.gamertag is string &&
             data.gamertag.size() < 30;
    }

    function isValidMatch(data) {
      return data.id is string &&
             data.mode is string &&
             data.players is list;
    }

    // Rules
    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create: if isOwner(uid) && isValidUser(request.resource.data);
      allow update: if isOwner(uid) && isValidUser(request.resource.data);
    }

    match /matches/{matchId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidMatch(request.resource.data);
      allow update, delete: if false;
    }

    // Legacy support for stats/maps if needed, but we'll migrate to users/matches
    match /stats/{userId} {
      allow read: if true;
      allow write: if isOwner(userId);
    }
    match /maps/{mapId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
  }
}
